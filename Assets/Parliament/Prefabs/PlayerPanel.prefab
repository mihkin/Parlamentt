  m_text: "\u041F\u041E \u2014 \u0440\u0435\u0441\u0443\u0440\u0441 \u0434\u043B\u044F
    \u0434\u043E\u0431\u043E\u0440\u0430, \u0433\u043E\u043B\u043E\u0441\u043E\u0432\u0430\u043D\u0438\u0439,
