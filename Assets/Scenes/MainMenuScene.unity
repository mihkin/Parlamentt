      m_Calls: []
  m_text: "1. \u0421\u044B\u0433\u0440\u044B\u0432\u0430\u0439\u0442\u0435 \u043A\u0430\u0440\u0442\u044B,
    \u0447\u0442\u043E\u0431\u044B \u0434\u0430\u0432\u0438\u0442\u044C \u043D\u0430
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u0438 \u0442\u0435\u043C\u043F.\n2.
    \u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043E\u0447\u043A\u0438
    \u0442\u0440\u0430\u0442\u044F\u0442\u0441\u044F \u043D\u0430 \u0440\u043E\u0437\u044B\u0433\u0440\u044B\u0448
    \u043A\u0430\u0440\u0442.\n3. \u0421\u043B\u0435\u0434\u0438\u0442\u0435 \u0437\u0430
    \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A\u0430\u043C\u0438 \u0438
    \u043D\u0435 \u043E\u0442\u0434\u0430\u0432\u0430\u0439\u0442\u0435 \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u0438\u0432\u0443
    \u0431\u043E\u0442\u0430\u043C.\n4. \u0413\u043E\u043B\u043E\u0441\u043E\u0432\u0430\u043D\u0438\u044F
